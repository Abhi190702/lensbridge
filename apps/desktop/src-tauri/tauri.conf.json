{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LensBridge Desktop",
  "version": "0.1.0",
  "identifier": "dev.lensbridge.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LensBridge Desktop",
        "create": false,
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "center": true,
        "visible": true,
        "skipTaskbar": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Bridge camera sources into desktop apps.",
    "longDescription": "LensBridge is a local-first universal camera bridge.",
    "icon": ["icons/icon.ico"]
  }
}
